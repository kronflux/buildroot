# Boot
CONFIG_CMDLINE="user_debug=31 init=/etc/overlay_init"

# Bluetooth
CONFIG_BT_RFCOMM_TTY=y

# USB gadget
CONFIG_USB_CONFIGFS_UEVENT=y
CONFIG_USB_CONFIGFS_F_ACC=y

# USB serial gadget for debugging
CONFIG_USB_F_ACM=y

# Filesystem / IPC
CONFIG_IO_URING=y
CONFIG_OVERLAY_FS=y
CONFIG_POSIX_MQUEUE=y

# Enable preemptible kernel for lower scheduling latency
CONFIG_PREEMPT=y

# Use performance CPU governor by default (USB-powered, no battery concern)
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND=n

# Disable bnep in bluetooth
CONFIG_BT_BNEP=n

# Disable legacy wireless extensions (use nl80211 only)
CONFIG_WIRELESS_EXT=n
CONFIG_WEXT_SPY=n
CONFIG_WEXT_PRIV=n

# Disable some kernel debugging options
CONFIG_DEBUG_BUGVERBOSE=n
CONFIG_DEBUG_FS=n
CONFIG_KGDB=n
CONFIG_DEBUG_MEMORY_INIT=n
CONFIG_FTRACE=n
CONFIG_SLUB_DEBUG=n

# Disable selected subsystems and options
CONFIG_VIRTUALIZATION=n
CONFIG_RANDOMIZE_BASE=n
CONFIG_MITIGATE_SPECTRE_BRANCH_HISTORY=n
CONFIG_SECURITY_APPARMOR=n
CONFIG_MEDIA_SUPPORT=n
CONFIG_SOUND=n
CONFIG_DRM=n
CONFIG_W1=n
CONFIG_CAN=n
CONFIG_HAMRADIO=n
CONFIG_NFC=n
CONFIG_NET_9P=n
CONFIG_FRAMEBUFFER_CONSOLE=n
CONFIG_TCG_TPM=n

# Disable device drivers
CONFIG_ATA=n
CONFIG_MD=n
CONFIG_PPP=n
CONFIG_IEEE802154_DRIVERS=n
CONFIG_SLIP=n
CONFIG_ATM_DRIVERS=n
CONFIG_NETCONSOLE=n
CONFIG_NET_CORE=n
CONFIG_BLK_DEV=n
CONFIG_INPUT_JOYSTICK=n
CONFIG_INPUT_TOUCHSCREEN=n
CONFIG_INPUT_MISC=n
CONFIG_RC_CORE=n
CONFIG_ACCESSIBILITY=n
CONFIG_RTC_CLASS=n
CONFIG_STAGING=n
CONFIG_SURFACE_PLATFORMS=n
CONFIG_RAS=n
CONFIG_IIO=n

# Disable filesystems
CONFIG_REISERFS_FS=n
CONFIG_JFS_FS=n
CONFIG_XFS_FS=n
CONFIG_GFS2_FS=n
CONFIG_OCFS2_FS=n
CONFIG_BTRFS_FS=n
CONFIG_NILFS2_FS=n
CONFIG_F2FS_FS=n
CONFIG_BCACHEFS_FS=n
CONFIG_QUOTA=n
CONFIG_FUSE_FS=n
CONFIG_ISO9660_FS=n
CONFIG_UDF_FS=n
CONFIG_NTFS3_FS=n
CONFIG_ECRYPT_FS=n
CONFIG_HFS_FS=n
CONFIG_HFSPLUS_FS=n
CONFIG_JFFS2_FS=n
CONFIG_UBIFS_FS=n
CONFIG_SQUASHFS=n
CONFIG_NETWORK_FILESYSTEMS=n

# Disable networking options
CONFIG_IPV6=n
CONFIG_XFRM_USER=n
CONFIG_XFRM_INTERFACE=n
CONFIG_XFRM_SUB_POLICY=n
CONFIG_XFRM_STATISTICS=n
CONFIG_NET_KEY=n
CONFIG_IP_MULTICAST=n
CONFIG_IP_MULTIPLE_TABLES=n
CONFIG_IP_ROUTE_MULTIPATH=n
CONFIG_IP_ROUTE_VERBOSE=n
CONFIG_IP_PNP=n
CONFIG_NET_IPIP=n
CONFIG_NET_IPGRE_DEMUX=n
CONFIG_NET_IPVTI=n
CONFIG_INET_AH=n
CONFIG_INET_ESP=n
CONFIG_INET_IPCOMP=n
CONFIG_INET_DIAG=n
CONFIG_TCP_CONG_ADVANCED=y
CONFIG_MPTCP=n
CONFIG_NETFILTER=n
CONFIG_ATM=n
CONFIG_L2TP=n
CONFIG_VLAN_8021Q=n
CONFIG_ATALK=n
CONFIG_6LOWPAN=n
CONFIG_IEEE802154=n
# Enable traffic control and fq_codel for WiFi QoS / anti-bufferbloat
CONFIG_NET_SCHED=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_DEFAULT=y
CONFIG_DEFAULT_FQ_CODEL=y
CONFIG_BATMAN_ADV=n
CONFIG_OPENVSWITCH=n
CONFIG_VSOCKETS=n
CONFIG_MPLS=n
CONFIG_NET_NSH=n
CONFIG_NET_L3_MASTER_DEV=n
CONFIG_NET_PKTGEN=n
CONFIG_LWTUNNEL=n

# Disable WLAN power save by default
CONFIG_CFG80211_DEFAULT_PS=n
