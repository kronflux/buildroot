software =
{
	version = "0.0.0";

	rpi = {
		hardware-compatibility: [ "1.0"];
		stable : {
			part1 : {
				images: (
					{
						filename = "rootfs.ext4";
						type = "raw";
                        installed-directly = true;
						device = "/dev/mmcblk0p2";
					}
				);
				bootenv: (
					{
						name = "bootpart";
						value = "2";
					},
					{
						name = "ustate";
						value = "1";
					}
				);
			};
			part2 : {
				images: (
					{
						filename = "rootfs.ext4";
						type = "raw";
                        installed-directly = true;
						device = "/dev/mmcblk0p3";
					}
				);
				bootenv: (
					{
						name = "bootpart";
						value = "3";
					},
					{
						name = "ustate";
						value = "1";
					}
				);
			};
		};
	}
}