BR2_arm=y
BR2_cortex_a7=y
BR2_ARM_FPU_NEON_VFPV4=y
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TOOLCHAIN_EXTERNAL_BOOTLIN=y
BR2_TOOLCHAIN_EXTERNAL_BOOTLIN_ARMV7_EABIHF_GLIBC_STABLE=y
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_GIT=y
BR2_LINUX_KERNEL_CUSTOM_REPO_URL="https://github.com/cpebit/kernel"
BR2_LINUX_KERNEL_CUSTOM_REPO_VERSION="13aec2ef33478782ceb25c00f211fae6ff662592"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_AA_PROXY_OS_PATH)/board/aaw-common/kernel.config.part"
BR2_LINUX_KERNEL_DTS_SUPPORT=y
BR2_LINUX_KERNEL_IMAGE_TARGET_CUSTOM=y
BR2_LINUX_KERNEL_IMAGE_NAME="../../../boot.img" # This is a bit of a hack
BR2_LINUX_KERNEL_XZ=y
BR2_TARGET_UBOOT=y
BR2_TARGET_UBOOT_BUILD_SYSTEM_KCONFIG=y
BR2_TARGET_UBOOT_CUSTOM_GIT=y
BR2_TARGET_UBOOT_CUSTOM_REPO_URL="https://github.com/cpebit/u-boot.git"
BR2_TARGET_UBOOT_CUSTOM_REPO_VERSION="c5f74e02418bbcceeead2865a0d1d249ff7056a3"
BR2_TARGET_UBOOT_NEEDS_DTC=y
BR2_TARGET_UBOOT_CUSTOM_MAKEOPTS="KCFLAGS=-Wno-error"
BR2_TARGET_UBOOT_ROCKCHIP=y
BR2_PACKAGE_HOST_UBOOT_TOOLS=y
BR2_PACKAGE_HOST_UBOOT_TOOLS_FIT_SUPPORT=y
BR2_PACKAGE_HOST_MTD=y
BR2_TARGET_ROOTFS_SQUASHFS=y
BR2_TARGET_ROOTFS_SQUASHFS4_ZSTD=y
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_AA_PROXY_OS_PATH)/rootfs_overlay $(BR2_EXTERNAL_AA_PROXY_OS_PATH)/board/aaw-common/rootfs_overlay"
BR2_PACKAGE_HOST_GENIMAGE=y
BR2_TARGET_GENERIC_GETTY=y
BR2_TARGET_GENERIC_GETTY_BAUDRATE_115200=y

# Packages
BR2_PACKAGE_LIBUBOOTENV=y
BR2_PACKAGE_RKWIFIBT=y
BR2_PACKAGE_BLUEZ=y
BR2_PACKAGE_SWUPDATE=y
BR2_PACKAGE_MTD=y
BR2_PACKAGE_LIBCONFIG=y
BR2_PACKAGE_ZLIB=y
BR2_PACKAGE_OPENSSL=y
BR2_PACKAGE_SWUPDATE_WEBSERVER=y
BR2_PACKAGE_SWUPDATE_CONFIG="$(BR2_EXTERNAL_AA_PROXY_OS_PATH)/board/aaw-common/swupdate.config"
BR2_PACKAGE_HOST_SWUGENERATOR=y
BR2_PACKAGE_BOOTCOUNT_RESET=y
